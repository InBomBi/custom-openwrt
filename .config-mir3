# Target (Giữ nguyên)
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7620=y
CONFIG_TARGET_ramips_mt7620_DEVICE_xiaomi_miwifi-r3=y

# Hệ thống file cho USB (Nếu có cắm ổ cứng/USB)
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-nls-utf8=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y

# Tối ưu hóa mạng (Nên giữ)
CONFIG_PACKAGE_kmod-sched-cake=y
CONFIG_PACKAGE_luci-app-sqm=y # Giúp giảm lag khi chơi game/xem phim

# Wifi (Bắt buộc cho R3)
CONFIG_PACKAGE_kmod-mt7603=y
CONFIG_PACKAGE_kmod-mt76x2=y
CONFIG_PACKAGE_wpad-wolfssl=y # Bản đầy đủ để hỗ trợ mesh/802.11r

# Giao diện (Rút gọn)
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-theme-edge=y # Hoặc bootstrap cho nhẹ
# CONFIG_LUCI_LANG_ru is not set
